# Copy to .env and fill in for production.

# Port the Node service listens on (nginx proxies to this).
PORT=4321

# Long random string — signs session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Password hash for the editor login. Generate with:
#   node bin/set-password.js "your-password"
ADMIN_PASSWORD_HASH=

# Production paths (where markdown lives and where static HTML is written).
# PUBLIC_DIR must be the nginx-served folder for /dnevnik.
# POSTS_DIR=/var/www/osokin.ai/.dnevnik-posts
# PUBLIC_DIR=/var/www/osokin.ai/dnevnik

# Set in production so cookies are marked Secure and dev fallbacks are off.
NODE_ENV=production
